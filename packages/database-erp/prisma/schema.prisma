generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Foundation-only metadata table for Prisma connectivity verification.
/// ERP business entities are introduced in post-RC00 sprints per docs/17.
model PlatformSchemaMetadata {
  id        String   @id @default(cuid())
  version   String   @default("0.1.0")
  updatedAt DateTime @updatedAt

  @@map("platform_schema_metadata")
}

/// Institutional role granted to an employee identity.
/// RC01 defines a single role; broader RBAC is deferred to later releases.
enum EmployeeRole {
  JR_BUSINESS_ANALYST
}

/// The employing organization of the simulated enterprise universe
/// (NordHabitat). Introduced in RC01 — Identity & First Day.
model Company {
  id        String   @id @default(cuid())
  /// Stable business key (e.g. "NORDHABITAT") — safe for idempotent seeding.
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]

  @@map("company")
}

/// An employee identity and its authentication credentials.
/// The student is modelled as an employee, never as a "learner".
model Employee {
  id             String       @id @default(cuid())
  /// Corporate employee number, e.g. "#NHE-DEMO" or "#NHE-2847".
  employeeNumber String       @unique
  email          String       @unique
  displayName    String
  /// scrypt-format credential hash (see @tec-platform/core Password). Never a plaintext password.
  passwordHash   String
  role           EmployeeRole @default(JR_BUSINESS_ANALYST)
  companyId      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  messageStates EmployeeMessageState[]
  taskStates    EmployeeTaskState[]
  missionAttempts EmployeeMissionAttempt[]

  courseProgress      EmployeeCourseProgress[]
  moduleProgress      EmployeeModuleProgress[]
  v1MissionAttempts   MissionAttempt[]
  unlockStates        UnlockState[]

  @@index([companyId])
  @@map("employee")
}

/// Per-employee read state for a static inbox message (content lives in code).
model EmployeeMessageState {
  id         String    @id @default(cuid())
  employeeId String
  messageKey String
  readAt     DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, messageKey])
  @@index([employeeId])
  @@map("employee_message_state")
}

/// Per-employee completion state for a static task (content lives in code).
model EmployeeTaskState {
  id          String   @id @default(cuid())
  employeeId  String
  taskKey     String
  completedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, taskKey])
  @@index([employeeId])
  @@map("employee_task_state")
}

/// Per-employee attempt state for a static mission (content lives in code).
/// locked/available are derived; only in_progress and completed rows are persisted.
model EmployeeMissionAttempt {
  id                        String    @id @default(cuid())
  employeeId                String
  missionKey                String
  /// Persisted values: in_progress | completed
  status                    String
  startedAt                 DateTime
  completedAt               DateTime?
  /// Context keys explicitly acknowledged in the submission (JSON string array).
  acknowledgedInputKeys     Json      @default("[]")
  /// Submitted department/problem pairs (JSON array of { departmentKey, problemKey }).
  departmentProblemMappings Json      @default("[]")
  justification             String?
  feedbackKey               String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, missionKey])
  @@index([employeeId])
  @@map("employee_mission_attempt")
}

/// V1 course catalog entry (code-registered content mirrored in DB).
model Course {
  id        String   @id @default(cuid())
  code      String   @unique
  title     String
  version   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  modules  CourseModule[]
  progress EmployeeCourseProgress[]

  @@map("course")
}

model CourseModule {
  id         String   @id @default(cuid())
  courseId   String
  moduleCode String   @unique
  title      String
  sequence   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  course    Course                   @relation(fields: [courseId], references: [id])
  missions  MissionDefinition[]
  progress  EmployeeModuleProgress[]

  @@index([courseId])
  @@map("course_module")
}

model MissionDefinition {
  id                   String   @id @default(cuid())
  moduleId             String
  missionCode          String   @unique
  missionKey           String   @unique
  title                String
  sequence             Int
  maxAttempts          Int      @default(2)
  passThresholdPercent Int      @default(70)
  estimatedMinutes     Int?
  difficulty           String?
  definitionJson       Json
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  module       CourseModule         @relation(fields: [moduleId], references: [id])
  competencies MissionCompetency[]
  attempts     MissionAttempt[]

  @@index([moduleId])
  @@map("mission_definition")
}

model Competency {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  missions MissionCompetency[]

  @@map("competency")
}

model MissionCompetency {
  id                  String @id @default(cuid())
  missionDefinitionId String
  competencyId        String
  weight              Float  @default(1)

  missionDefinition MissionDefinition @relation(fields: [missionDefinitionId], references: [id])
  competency        Competency        @relation(fields: [competencyId], references: [id])

  @@unique([missionDefinitionId, competencyId])
  @@index([missionDefinitionId])
  @@index([competencyId])
  @@map("mission_competency")
}

model EmployeeCourseProgress {
  id              String   @id @default(cuid())
  employeeId      String
  courseId        String
  percentComplete Float    @default(0)
  status          String   @default("locked")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
  course   Course   @relation(fields: [courseId], references: [id])

  @@unique([employeeId, courseId])
  @@index([employeeId])
  @@index([courseId])
  @@map("employee_course_progress")
}

model EmployeeModuleProgress {
  id              String   @id @default(cuid())
  employeeId      String
  moduleId        String
  percentComplete Float    @default(0)
  status          String   @default("locked")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee Employee     @relation(fields: [employeeId], references: [id])
  module   CourseModule @relation(fields: [moduleId], references: [id])

  @@unique([employeeId, moduleId])
  @@index([employeeId])
  @@index([moduleId])
  @@map("employee_module_progress")
}

/// Persisted attempt lifecycle. locked/available are derived, never stored.
model MissionAttempt {
  id                  String    @id @default(cuid())
  employeeId          String
  missionDefinitionId String
  attemptNumber       Int
  /// Persisted: in_progress | submitted | completed | needs_review | failed
  status              String
  startedAt           DateTime
  submittedAt         DateTime?
  completedAt         DateTime?
  responsesJson       Json      @default("{}")
  scorePercent        Float?
  earnedPoints        Float?
  maxPoints           Float?
  feedbackJson        Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  employee          Employee          @relation(fields: [employeeId], references: [id])
  missionDefinition MissionDefinition @relation(fields: [missionDefinitionId], references: [id])
  evidence          MissionEvidence[]
  feedbackRecords   FeedbackRecord[]

  @@unique([employeeId, missionDefinitionId, attemptNumber])
  @@index([employeeId])
  @@index([missionDefinitionId])
  @@map("mission_attempt")
}

model MissionEvidence {
  id          String   @id @default(cuid())
  attemptId   String
  kind        String
  payloadJson Json
  createdAt   DateTime @default(now())

  attempt MissionAttempt @relation(fields: [attemptId], references: [id])

  @@index([attemptId])
  @@map("mission_evidence")
}

model UnlockState {
  id           String   @id @default(cuid())
  employeeId   String
  resourceType String
  resourceKey  String
  unlockedAt   DateTime
  createdAt    DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, resourceType, resourceKey])
  @@index([employeeId])
  @@map("unlock_state")
}

model FeedbackRecord {
  id        String   @id @default(cuid())
  attemptId String
  scope     String
  message   String
  createdAt DateTime @default(now())

  attempt MissionAttempt @relation(fields: [attemptId], references: [id])

  @@index([attemptId])
  @@map("feedback_record")
}
