generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Foundation-only metadata table for Prisma connectivity verification.
/// ERP business entities are introduced in post-RC00 sprints per docs/17.
model PlatformSchemaMetadata {
  id        String   @id @default(cuid())
  version   String   @default("0.1.0")
  updatedAt DateTime @updatedAt

  @@map("platform_schema_metadata")
}

/// Institutional role granted to an employee identity.
/// RC01 defines a single role; broader RBAC is deferred to later releases.
enum EmployeeRole {
  JR_BUSINESS_ANALYST
  PROFESSOR
  ADMIN
}

/// The employing organization of the simulated enterprise universe
/// (NordHabitat). Introduced in RC01 — Identity & First Day.
model Company {
  id        String   @id @default(cuid())
  /// Stable business key (e.g. "NORDHABITAT") — safe for idempotent seeding.
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees            Employee[]
  cohorts              Cohort[]
  masterDataRecords    MasterDataRecord[]
  businessDocuments    BusinessDocument[]
  inventoryMovements   InventoryMovement[]
  financialPostings    FinancialPosting[]
  openItems            OpenItem[]
  transactionEvents    TransactionEvent[]
  auditEvents          AuditEvent[]
  simulationSnapshots  SimulationSnapshot[]
  configuration        CompanyConfiguration?
  aiPolicy             AiPolicy?
  kpiRecords           KpiRecord[]
  aiInteractions       AiInteraction[]
  integrationConnections IntegrationConnection[]
  featureFlags         FeatureFlag[]
  pedagogicalCourseRuns PedagogicalCourseRun[]

  @@map("company")
}

/// An employee identity and its authentication credentials.
/// The student is modelled as an employee, never as a "learner".
model Employee {
  id             String       @id @default(cuid())
  /// Corporate employee number, e.g. "#NHE-DEMO" or "#NHE-2847".
  employeeNumber String       @unique
  email          String       @unique
  displayName    String
  /// scrypt-format credential hash (see @tec-platform/core Password). Never a plaintext password.
  passwordHash   String
  role           EmployeeRole @default(JR_BUSINESS_ANALYST)
  companyId      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  messageStates EmployeeMessageState[]
  taskStates    EmployeeTaskState[]
  missionAttempts EmployeeMissionAttempt[]

  courseProgress       EmployeeCourseProgress[]
  moduleProgress       EmployeeModuleProgress[]
  v1MissionAttempts    MissionAttempt[]
  unlockStates         UnlockState[]
  cohortMemberships    CohortMembership[]
  masterDataAudits     MasterDataAudit[]
  approvalDecisions    ApprovalDecision[]
  assessmentAttempts   AssessmentAttempt[]
  certificates         Certificate[]
  certificateAudits    CertificateAudit[]
  auditEventsActed     AuditEvent[]              @relation("AuditActor")
  aiInteractions       AiInteraction[]
  capstoneSubmissions  CapstoneSubmission[]
  missionDrafts        MissionDraft[]
  missionVersions      MissionVersion[]          @relation("MissionVersionPublisher")
  scenarioPublications ScenarioPublication[]
  predictionRecords    PredictionRecord[]        @relation("PredictionStudent")
  automationExecutions AutomationExecution[]
  pedagogicalCourseRuns PedagogicalCourseRun[]   @relation("PedagogicalRunStudent")
  pedagogicalRunsAsProfessor PedagogicalCourseRun[] @relation("PedagogicalRunProfessor")
  pedagogicalRunsCreated PedagogicalCourseRun[]  @relation("PedagogicalRunCreator")
  professorInterventions ProfessorIntervention[]
  studentMissionReflections StudentMissionReflection[]
  pedagogicalRunAudits PedagogicalCourseRunAudit[] @relation("PedagogicalRunAuditActor")

  @@index([companyId])
  @@map("employee")
}

/// Per-employee read state for a static inbox message (content lives in code).
model EmployeeMessageState {
  id         String    @id @default(cuid())
  employeeId String
  messageKey String
  readAt     DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, messageKey])
  @@index([employeeId])
  @@map("employee_message_state")
}

/// Per-employee completion state for a static task (content lives in code).
model EmployeeTaskState {
  id          String   @id @default(cuid())
  employeeId  String
  taskKey     String
  completedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, taskKey])
  @@index([employeeId])
  @@map("employee_task_state")
}

/// Per-employee attempt state for a static mission (content lives in code).
/// locked/available are derived; only in_progress and completed rows are persisted.
model EmployeeMissionAttempt {
  id                        String    @id @default(cuid())
  employeeId                String
  missionKey                String
  /// Persisted values: in_progress | completed
  status                    String
  startedAt                 DateTime
  completedAt               DateTime?
  /// Context keys explicitly acknowledged in the submission (JSON string array).
  acknowledgedInputKeys     Json      @default("[]")
  /// Submitted department/problem pairs (JSON array of { departmentKey, problemKey }).
  departmentProblemMappings Json      @default("[]")
  justification             String?
  feedbackKey               String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, missionKey])
  @@index([employeeId])
  @@map("employee_mission_attempt")
}

/// V1 course catalog entry (code-registered content mirrored in DB).
model Course {
  id        String   @id @default(cuid())
  code      String   @unique
  title     String
  version   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  modules  CourseModule[]
  progress EmployeeCourseProgress[]
  pedagogicalCourseRuns PedagogicalCourseRun[]

  @@map("course")
}

/// First-class versioned pedagogical course run (repeatable teaching without overwrite).
model PedagogicalCourseRun {
  id                 String    @id @default(cuid())
  companyId          String
  cohortId           String?
  employeeId         String
  professorId        String?
  courseId           String
  runCode            String    @unique
  runSequence        Int
  /// AUTONOMOUS | INSTRUCTOR_LED | REMEDIATION | DEMONSTRATION
  runType            String
  runLabel           String
  language           String    @default("fr")
  /// PLANNED | ACTIVE | PAUSED | COMPLETED | CANCELLED | ARCHIVED
  status             String
  sourceRunId        String?
  startedAt          DateTime?
  pausedAt           DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  createdById        String
  completionPercent  Float     @default(0)
  metadataJson       Json      @default("{}")

  company   Company  @relation(fields: [companyId], references: [id])
  cohort    Cohort?  @relation(fields: [cohortId], references: [id])
  employee  Employee @relation("PedagogicalRunStudent", fields: [employeeId], references: [id])
  professor Employee? @relation("PedagogicalRunProfessor", fields: [professorId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])
  createdBy Employee @relation("PedagogicalRunCreator", fields: [createdById], references: [id])
  sourceRun PedagogicalCourseRun?  @relation("PedagogicalRunLineage", fields: [sourceRunId], references: [id])
  derivedRuns PedagogicalCourseRun[] @relation("PedagogicalRunLineage")

  courseProgress   EmployeeCourseProgress[]
  moduleProgress   EmployeeModuleProgress[]
  missionAttempts  MissionAttempt[]
  unlockStates     UnlockState[]
  assessmentAttempts AssessmentAttempt[]
  capstoneSubmissions CapstoneSubmission[]
  aiInteractions   AiInteraction[]
  certificates     Certificate[]             @relation("CertificateSourceRun")
  interventions    ProfessorIntervention[]
  reflections      StudentMissionReflection[]
  audits           PedagogicalCourseRunAudit[]

  @@unique([employeeId, courseId, runSequence])
  @@index([companyId])
  @@index([employeeId, status])
  @@index([cohortId])
  @@map("pedagogical_course_run")
}

model PedagogicalCourseRunAudit {
  id        String   @id @default(cuid())
  runId     String
  actorId   String
  action    String
  fromStatus String?
  toStatus   String?
  reason    String?
  payloadJson Json   @default("{}")
  createdAt DateTime @default(now())

  run   PedagogicalCourseRun @relation(fields: [runId], references: [id])
  actor Employee             @relation("PedagogicalRunAuditActor", fields: [actorId], references: [id])

  @@index([runId, createdAt])
  @@map("pedagogical_course_run_audit")
}

model ProfessorIntervention {
  id                   String   @id @default(cuid())
  runId                String
  moduleCode           String?
  missionCode          String?
  professorId          String
  /// NONE | CLARIFICATION | CONCEPT_EXPLANATION | PROCESS_DEMONSTRATION | TERMINOLOGY_SUPPORT | DATA_INTERPRETATION | ERROR_RECOVERY | BUSINESS_CONTEXT | KPI_EXPLANATION | AI_GOVERNANCE | FULL_RETEACH
  interventionType     String
  durationMinutes      Int?
  reason               String
  content              String
  outcome              String?
  shouldSystemTeach    Boolean?
  learningHubCandidate Boolean?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  run       PedagogicalCourseRun @relation(fields: [runId], references: [id])
  professor Employee             @relation(fields: [professorId], references: [id])

  @@index([runId, createdAt])
  @@map("professor_intervention")
}

model StudentMissionReflection {
  id                         String   @id @default(cuid())
  runId                      String
  missionKey                 String
  employeeId                 String
  clarity                    Int
  confidence                 Int
  cognitiveLoad              Int
  realism                    Int
  relevance                  Int
  navigationQuality          Int
  feedbackQuality            Int
  visualQuality              Int
  aiUsefulness               Int?
  biUsefulness               Int?
  externalExplanationRequired Boolean @default(false)
  externalSlidesWouldHelp    Boolean  @default(false)
  qualitativeNote            String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  run      PedagogicalCourseRun @relation(fields: [runId], references: [id])
  employee Employee             @relation(fields: [employeeId], references: [id])

  @@unique([runId, missionKey, employeeId])
  @@index([runId])
  @@map("student_mission_reflection")
}

model CourseModule {
  id         String   @id @default(cuid())
  courseId   String
  moduleCode String   @unique
  title      String
  sequence   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  course    Course                   @relation(fields: [courseId], references: [id])
  missions  MissionDefinition[]
  progress  EmployeeModuleProgress[]

  @@index([courseId])
  @@map("course_module")
}

model MissionDefinition {
  id                   String   @id @default(cuid())
  moduleId             String
  missionCode          String   @unique
  missionKey           String   @unique
  title                String
  sequence             Int
  maxAttempts          Int      @default(2)
  passThresholdPercent Int      @default(70)
  estimatedMinutes     Int?
  difficulty           String?
  definitionJson       Json
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  module       CourseModule         @relation(fields: [moduleId], references: [id])
  competencies MissionCompetency[]
  attempts     MissionAttempt[]

  @@index([moduleId])
  @@map("mission_definition")
}

model Competency {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  missions MissionCompetency[]

  @@map("competency")
}

model MissionCompetency {
  id                  String @id @default(cuid())
  missionDefinitionId String
  competencyId        String
  weight              Float  @default(1)

  missionDefinition MissionDefinition @relation(fields: [missionDefinitionId], references: [id])
  competency        Competency        @relation(fields: [competencyId], references: [id])

  @@unique([missionDefinitionId, competencyId])
  @@index([missionDefinitionId])
  @@index([competencyId])
  @@map("mission_competency")
}

model EmployeeCourseProgress {
  id                      String   @id @default(cuid())
  employeeId              String
  courseId                String
  pedagogicalCourseRunId  String
  percentComplete         Float    @default(0)
  status                  String   @default("locked")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  employee Employee             @relation(fields: [employeeId], references: [id])
  course   Course               @relation(fields: [courseId], references: [id])
  pedagogicalCourseRun PedagogicalCourseRun @relation(fields: [pedagogicalCourseRunId], references: [id])

  @@unique([employeeId, courseId, pedagogicalCourseRunId])
  @@index([employeeId])
  @@index([courseId])
  @@index([pedagogicalCourseRunId])
  @@map("employee_course_progress")
}

model EmployeeModuleProgress {
  id                      String   @id @default(cuid())
  employeeId              String
  moduleId                String
  pedagogicalCourseRunId  String
  percentComplete         Float    @default(0)
  status                  String   @default("locked")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  employee Employee     @relation(fields: [employeeId], references: [id])
  module   CourseModule @relation(fields: [moduleId], references: [id])
  pedagogicalCourseRun PedagogicalCourseRun @relation(fields: [pedagogicalCourseRunId], references: [id])

  @@unique([employeeId, moduleId, pedagogicalCourseRunId])
  @@index([employeeId])
  @@index([moduleId])
  @@index([pedagogicalCourseRunId])
  @@map("employee_module_progress")
}

/// Persisted attempt lifecycle. locked/available are derived, never stored.
model MissionAttempt {
  id                     String    @id @default(cuid())
  employeeId             String
  missionDefinitionId    String
  pedagogicalCourseRunId String
  attemptNumber          Int
  /// Persisted: in_progress | submitted | completed | needs_review | failed
  status                 String
  startedAt              DateTime
  submittedAt            DateTime?
  completedAt            DateTime?
  responsesJson          Json      @default("{}")
  scorePercent           Float?
  earnedPoints           Float?
  maxPoints              Float?
  feedbackJson           Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  employee          Employee          @relation(fields: [employeeId], references: [id])
  missionDefinition MissionDefinition @relation(fields: [missionDefinitionId], references: [id])
  pedagogicalCourseRun PedagogicalCourseRun @relation(fields: [pedagogicalCourseRunId], references: [id])
  evidence          MissionEvidence[]
  feedbackRecords   FeedbackRecord[]

  @@unique([employeeId, missionDefinitionId, pedagogicalCourseRunId, attemptNumber])
  @@index([employeeId])
  @@index([missionDefinitionId])
  @@index([pedagogicalCourseRunId])
  @@map("mission_attempt")
}

model MissionEvidence {
  id          String   @id @default(cuid())
  attemptId   String
  kind        String
  payloadJson Json
  createdAt   DateTime @default(now())

  attempt MissionAttempt @relation(fields: [attemptId], references: [id])

  @@index([attemptId])
  @@map("mission_evidence")
}

model UnlockState {
  id                     String   @id @default(cuid())
  employeeId             String
  resourceType           String
  resourceKey            String
  pedagogicalCourseRunId String
  unlockedAt             DateTime
  createdAt              DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
  pedagogicalCourseRun PedagogicalCourseRun @relation(fields: [pedagogicalCourseRunId], references: [id])

  @@unique([employeeId, resourceType, resourceKey, pedagogicalCourseRunId])
  @@index([employeeId])
  @@index([pedagogicalCourseRunId])
  @@map("unlock_state")
}

model FeedbackRecord {
  id        String   @id @default(cuid())
  attemptId String
  scope     String
  message   String
  createdAt DateTime @default(now())

  attempt MissionAttempt @relation(fields: [attemptId], references: [id])

  @@index([attemptId])
  @@map("feedback_record")
}

/// Wave 2 — cohort / professor scoping
model Cohort {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company            @relation(fields: [companyId], references: [id])
  memberships CohortMembership[]
  certificates Certificate[]
  pedagogicalCourseRuns PedagogicalCourseRun[]

  @@index([companyId])
  @@map("cohort")
}

model CohortMembership {
  id           String   @id @default(cuid())
  cohortId     String
  employeeId   String
  roleInCohort String
  createdAt    DateTime @default(now())

  cohort   Cohort   @relation(fields: [cohortId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([cohortId, employeeId])
  @@index([employeeId])
  @@map("cohort_membership")
}

model MasterDataRecord {
  id           String   @id @default(cuid())
  companyId    String
  entityType   String
  businessKey  String
  payloadJson  Json
  status       String   @default("active")
  qualityScore Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company           @relation(fields: [companyId], references: [id])
  audits  MasterDataAudit[]

  @@unique([companyId, entityType, businessKey])
  @@index([companyId])
  @@map("master_data_record")
}

model MasterDataAudit {
  id         String   @id @default(cuid())
  recordId   String
  employeeId String
  action     String
  beforeJson Json?
  afterJson  Json?
  createdAt  DateTime @default(now())

  record   MasterDataRecord @relation(fields: [recordId], references: [id])
  employee Employee         @relation(fields: [employeeId], references: [id])

  @@index([recordId])
  @@map("master_data_audit")
}

model BusinessDocument {
  id              String   @id @default(cuid())
  companyId       String
  employeeId      String?
  documentType    String
  documentNumber  String
  status          String
  payloadJson     Json
  missionKey      String?
  missionAttemptId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company    Company            @relation(fields: [companyId], references: [id])
  lines      DocumentLine[]
  approvals  ApprovalDecision[]
  movements  InventoryMovement[]
  postings   FinancialPosting[]
  openItems  OpenItem[]

  @@unique([companyId, documentType, documentNumber])
  @@index([companyId])
  @@index([missionKey])
  @@map("business_document")
}

model DocumentLine {
  id          String @id @default(cuid())
  documentId  String
  lineNumber  Int
  payloadJson Json

  document BusinessDocument @relation(fields: [documentId], references: [id])

  @@unique([documentId, lineNumber])
  @@map("document_line")
}

model ApprovalDecision {
  id         String   @id @default(cuid())
  documentId String
  employeeId String
  decision   String
  reason     String?
  decidedAt  DateTime

  document BusinessDocument @relation(fields: [documentId], references: [id])
  employee Employee         @relation(fields: [employeeId], references: [id])

  @@index([documentId])
  @@map("approval_decision")
}

model InventoryMovement {
  id               String   @id @default(cuid())
  companyId        String
  materialKey      String
  locationKey      String
  quantity         Float
  direction        String
  sourceDocumentId String?
  missionAttemptId String?
  postingKey       String   @unique
  createdAt        DateTime @default(now())

  company        Company           @relation(fields: [companyId], references: [id])
  sourceDocument BusinessDocument? @relation(fields: [sourceDocumentId], references: [id])

  @@index([companyId, materialKey, locationKey])
  @@map("inventory_movement")
}

model FinancialPosting {
  id               String   @id @default(cuid())
  companyId        String
  accountCode      String
  debit            Float    @default(0)
  credit           Float    @default(0)
  currency         String   @default("CAD")
  sourceDocumentId String?
  missionAttemptId String?
  postingKey       String   @unique
  createdAt        DateTime @default(now())

  company        Company           @relation(fields: [companyId], references: [id])
  sourceDocument BusinessDocument? @relation(fields: [sourceDocumentId], references: [id])

  @@index([companyId, accountCode])
  @@map("financial_posting")
}

model OpenItem {
  id          String   @id @default(cuid())
  companyId   String
  kind        String
  documentId  String
  amount      Float
  openAmount  Float
  status      String   @default("open")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  Company          @relation(fields: [companyId], references: [id])
  document BusinessDocument @relation(fields: [documentId], references: [id])

  @@index([companyId, status])
  @@map("open_item")
}

model TransactionEvent {
  id         String   @id @default(cuid())
  companyId  String
  employeeId String?
  eventType  String
  payloadJson Json
  sequence   Int
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, sequence])
  @@index([companyId])
  @@map("transaction_event")
}

model AuditEvent {
  id               String   @id @default(cuid())
  companyId        String
  actorEmployeeId  String
  action           String
  resourceType     String
  resourceKey      String
  reason           String?
  payloadJson      Json?
  createdAt        DateTime @default(now())

  company Company  @relation(fields: [companyId], references: [id])
  actor   Employee @relation("AuditActor", fields: [actorEmployeeId], references: [id])

  @@index([companyId, createdAt])
  @@map("audit_event")
}

model SimulationSnapshot {
  id          String   @id @default(cuid())
  companyId   String
  employeeId  String
  label       String
  payloadJson Json
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, employeeId])
  @@map("simulation_snapshot")
}

model AssessmentDefinition {
  id                   String   @id @default(cuid())
  code                 String   @unique
  title                String
  moduleScope          String
  passThresholdPercent Int      @default(70)
  maxAttempts          Int      @default(2)
  timeLimitSeconds     Int?
  definitionJson       Json
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  questions AssessmentQuestion[]
  attempts  AssessmentAttempt[]

  @@map("assessment_definition")
}

model AssessmentQuestion {
  id           String @id @default(cuid())
  assessmentId String
  questionKey  String
  sequence     Int
  type         String
  prompt       String
  optionsJson  Json
  scoringJson  Json

  assessment AssessmentDefinition @relation(fields: [assessmentId], references: [id])

  @@unique([assessmentId, questionKey])
  @@index([assessmentId])
  @@map("assessment_question")
}

model AssessmentAttempt {
  id                     String    @id @default(cuid())
  employeeId             String
  assessmentId           String
  pedagogicalCourseRunId String
  attemptNumber          Int
  status                 String
  startedAt              DateTime
  submittedAt            DateTime?
  scorePercent           Float?
  responsesJson          Json      @default("{}")
  feedbackJson           Json?

  employee   Employee             @relation(fields: [employeeId], references: [id])
  assessment AssessmentDefinition @relation(fields: [assessmentId], references: [id])
  pedagogicalCourseRun PedagogicalCourseRun @relation(fields: [pedagogicalCourseRunId], references: [id])

  @@unique([employeeId, assessmentId, pedagogicalCourseRunId, attemptNumber])
  @@index([employeeId])
  @@index([pedagogicalCourseRunId])
  @@map("assessment_attempt")
}

model Certificate {
  id                    String    @id @default(cuid())
  employeeId            String
  cohortId              String?
  sourceRunId           String?
  achievementType       String?
  certificateType       String
  certificateNumber     String    @unique
  issuedAt              DateTime
  status                String    @default("issued")
  competencySummaryJson Json
  verificationStatus    String    @default("valid")
  revokedAt             DateTime?
  revokeReason          String?

  employee  Employee              @relation(fields: [employeeId], references: [id])
  cohort    Cohort?               @relation(fields: [cohortId], references: [id])
  sourceRun PedagogicalCourseRun? @relation("CertificateSourceRun", fields: [sourceRunId], references: [id])
  audits                CertificateAudit[]
  verificationTokens    PublicVerificationToken[]

  @@index([employeeId])
  @@index([sourceRunId])
  @@map("certificate")
}

model CompanyConfiguration {
  id           String   @id @default(cuid())
  companyId    String   @unique
  settingsJson Json     @default("{}")
  aiEnabled    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@map("company_configuration")
}

model DashboardDefinition {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String
  description String
  category    String
  layoutJson  Json     @default("{}")
  kpiKeys     Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("dashboard_definition")
}

model KpiFormulaVersion {
  id          String   @id @default(cuid())
  kpiKey      String
  version     Int
  formulaJson Json
  createdAt   DateTime @default(now())

  @@unique([kpiKey, version])
  @@map("kpi_formula_version")
}

model KpiRecord {
  id           String   @id @default(cuid())
  companyId    String
  kpiKey       String
  value        Float?
  unit         String?
  stale        Boolean  @default(false)
  snapshotJson Json
  recordedAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, kpiKey, recordedAt])
  @@map("kpi_record")
}

model AiPolicy {
  id         String   @id @default(cuid())
  companyId  String   @unique
  aiEnabled  Boolean  @default(true)
  policyJson Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@map("ai_policy")
}

model AiInteraction {
  id                     String   @id @default(cuid())
  employeeId             String
  companyId              String
  pedagogicalCourseRunId String?
  question               String
  answer                 String
  refused                Boolean  @default(false)
  metadataJson           Json     @default("{}")
  createdAt              DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id])
  pedagogicalCourseRun PedagogicalCourseRun? @relation(fields: [pedagogicalCourseRunId], references: [id])

  @@index([employeeId, createdAt])
  @@index([pedagogicalCourseRunId])
  @@map("ai_interaction")
}

model PredictionRecord {
  id           String   @id @default(cuid())
  studentId    String
  professorId  String?
  modelVersion String
  payloadJson  Json
  createdAt    DateTime @default(now())

  student Employee @relation("PredictionStudent", fields: [studentId], references: [id])

  @@index([studentId, createdAt])
  @@map("prediction_record")
}

model CapstoneSubmission {
  id                     String    @id @default(cuid())
  employeeId             String
  pedagogicalCourseRunId String
  missionKey             String    @default("m10-m03-presentation-capstone-or")
  status                 String    @default("draft")
  diagnose               String?
  prioritize             String?
  execute                String?
  analyze                String?
  recommend              String?
  executiveSummary       String?
  submittedAt            DateTime?
  reviewStatus           String?
  professorApproved      Boolean   @default(false)
  professorNotes         String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  employee Employee           @relation(fields: [employeeId], references: [id])
  pedagogicalCourseRun PedagogicalCourseRun @relation(fields: [pedagogicalCourseRunId], references: [id])
  evidence CapstoneEvidence[]

  @@unique([employeeId, pedagogicalCourseRunId])
  @@index([pedagogicalCourseRunId])
  @@map("capstone_submission")
}

model CapstoneEvidence {
  id           String   @id @default(cuid())
  submissionId String
  kind         String
  payloadJson  Json
  createdAt    DateTime @default(now())

  submission CapstoneSubmission @relation(fields: [submissionId], references: [id])

  @@index([submissionId])
  @@map("capstone_evidence")
}

model MissionDraft {
  id               String   @id @default(cuid())
  missionKey       String
  authorEmployeeId String
  status           String   @default("draft")
  draftJson        Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  author   Employee         @relation(fields: [authorEmployeeId], references: [id])
  versions MissionVersion[]

  @@index([missionKey])
  @@map("mission_draft")
}

model MissionVersion {
  id                    String   @id @default(cuid())
  draftId               String?
  missionKey            String
  versionNumber         Int
  definitionJson        Json
  publishedAt           DateTime
  publishedByEmployeeId String
  status                String   @default("published")

  draft        MissionDraft?         @relation(fields: [draftId], references: [id])
  publisher    Employee              @relation("MissionVersionPublisher", fields: [publishedByEmployeeId], references: [id])
  publications ScenarioPublication[]

  @@unique([missionKey, versionNumber])
  @@map("mission_version")
}

model ScenarioPublication {
  id               String   @id @default(cuid())
  missionVersionId String
  action           String
  actorEmployeeId  String
  reason           String?
  createdAt        DateTime @default(now())

  missionVersion MissionVersion @relation(fields: [missionVersionId], references: [id])
  actor          Employee       @relation(fields: [actorEmployeeId], references: [id])

  @@index([missionVersionId])
  @@map("scenario_publication")
}

model IntegrationConnection {
  id         String   @id @default(cuid())
  companyId  String
  adapterKey String
  name       String
  configJson Json     @default("{}")
  secretRef  String?
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company          @relation(fields: [companyId], references: [id])
  runs    IntegrationRun[]

  @@index([companyId])
  @@map("integration_connection")
}

model IntegrationRun {
  id             String    @id @default(cuid())
  connectionId   String
  idempotencyKey String    @unique
  status         String
  retryCount     Int       @default(0)
  resultJson     Json?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  connection IntegrationConnection @relation(fields: [connectionId], references: [id])
  events       IntegrationEvent[]

  @@index([connectionId, startedAt])
  @@map("integration_run")
}

model IntegrationEvent {
  id          String   @id @default(cuid())
  runId       String
  eventType   String
  payloadJson Json
  createdAt   DateTime @default(now())

  run IntegrationRun @relation(fields: [runId], references: [id])

  @@index([runId])
  @@map("integration_event")
}

model AutomationRule {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String
  enabled     Boolean  @default(true)
  configJson  Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  executions AutomationExecution[]

  @@map("automation_rule")
}

model AutomationExecution {
  id         String   @id @default(cuid())
  ruleId     String
  companyId  String?
  employeeId String?
  status     String
  resultJson Json?
  createdAt  DateTime @default(now())

  rule     AutomationRule @relation(fields: [ruleId], references: [id])
  employee Employee?      @relation(fields: [employeeId], references: [id])

  @@index([ruleId, createdAt])
  @@map("automation_execution")
}

model PublicVerificationToken {
  id            String   @id @default(cuid())
  tokenHash     String   @unique
  certificateId String
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  certificate Certificate @relation(fields: [certificateId], references: [id])

  @@index([certificateId])
  @@map("public_verification_token")
}

model FeatureFlag {
  id        String   @id @default(cuid())
  key       String
  companyId String?
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id])

  @@unique([key, companyId])
  @@map("feature_flag")
}

model CertificateAudit {
  id               String   @id @default(cuid())
  certificateId    String
  actorEmployeeId  String
  action           String
  reason           String?
  createdAt        DateTime @default(now())

  certificate Certificate @relation(fields: [certificateId], references: [id])
  actor       Employee    @relation(fields: [actorEmployeeId], references: [id])

  @@index([certificateId])
  @@map("certificate_audit")
}
