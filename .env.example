# TEC.ERP — Environment Variable Catalog (RC00)
# Copy to .env for local development. Never commit .env files.
# Classification per ADR-PLATFORM-001 §13 and docs/26.

# --- Server (erp-api) ---

# Runtime environment: development | test | production
NODE_ENV=development

# API listen port (Railway injects PORT in cloud environments)
PORT=3000

# Allowed browser origin for CORS (must match erp-web dev/prod URL)
CORS_ORIGIN=http://localhost:5173

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info

# PostgreSQL connection string (Railway encrypted variable in staging/production)
DATABASE_URL=postgresql://tec:tec@localhost:5432/tec_erp

# --- Client (erp-web) — VITE_* prefix only; no secrets ---

# Base URL for API health and future REST calls
VITE_API_BASE_URL=http://localhost:3000

# --- Feature flags (default off until Approval Gate) ---

# Pedagogical AI Coach — post-RC00; scaffold name only
FEATURE_AI_COACH_ENABLED=false

# --- Auth (RC01 — Identity & First Day, Slice A) ---
# Secrets are Railway-encrypted and REQUIRED in production. Development uses
# safe built-in fallbacks; production fail-fast rejects the placeholder values.

# JWT access-token signing secret
# JWT_ACCESS_SECRET=
# JWT refresh-token signing secret
# JWT_REFRESH_SECRET=
# Access-token lifetime in seconds (default 900, i.e. 15 minutes)
# JWT_ACCESS_TTL_SECONDS=900
# Refresh-token lifetime in seconds (default 1209600, i.e. 14 days)
# JWT_REFRESH_TTL_SECONDS=1209600
